{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "ngxsmk-datepicker": {
      "projectType": "library",
      "root": "projects/ngxsmk-datepicker",
      "sourceRoot": "projects/ngxsmk-datepicker/src",
      "prefix": "ngxsmk",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/ngxsmk-datepicker/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/ngxsmk-datepicker/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "tsConfig": "projects/ngxsmk-datepicker/tsconfig.spec.json",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "codeCoverage": true,
            "codeCoverageExclude": [
              "**/*.spec.ts",
              "**/node_modules/**",
              "**/dist/**",
              "**/*.module.ts"
            ],
            "karmaConfig": "projects/ngxsmk-datepicker/karma.conf.js"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/ngxsmk-datepicker/**/*.ts",
              "projects/ngxsmk-datepicker/**/*.html"
            ]
          }
        }
      }
    },
    "demo-app": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/demo-app",
      "sourceRoot": "projects/demo-app/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/demo-app",
            "browser": "projects/demo-app/src/main.ts",
            "tsConfig": "projects/demo-app/tsconfig.app.json",
            "preserveSymlinks": true,
            "polyfills": [
              "zone.js"
            ],
            "allowedCommonJsDependencies": [
              "@tokiforge/core"
            ],
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/demo-app/public"
              },
              "projects/demo-app/src/_redirects",
              {
                "glob": "robots.txt",
                "input": "projects/demo-app/public",
                "output": "/"
              },
              {
                "glob": "sitemap.xml",
                "input": "projects/demo-app/public",
                "output": "/"
              }
            ],
            "styles": [
              "projects/demo-app/src/styles.scss"
            ]
          },
          "configurations": {
            "production": {
              "outputPath": "dist/demo-app",
              "baseHref": "/ngxsmk-datepicker/",
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1.5MB",
                  "maximumError": "2MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "150kB",
                  "maximumError": "170kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "demo-app:build:production"
            },
            "development": {
              "buildTarget": "demo-app:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n"
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "projects/demo-app/tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/demo-app/public"
              }
            ],
            "styles": [
              "projects/demo-app/src/styles.scss"
            ]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/demo-app/**/*.ts",
              "projects/demo-app/**/*.html"
            ]
          }
        }
      }
    },
    "angular-issue-test": {
      "projectType": "application",
      "root": "examples/angular-issue-test",
      "sourceRoot": "examples/angular-issue-test/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/angular-issue-test",
            "browser": "examples/angular-issue-test/src/main.ts",
            "tsConfig": "examples/angular-issue-test/tsconfig.app.json",
            "preserveSymlinks": true,
            "polyfills": [
              "zone.js"
            ],
            "assets": [],
            "styles": [
              "examples/angular-issue-test/src/styles.scss"
            ]
          },
          "configurations": {
            "production": {
              "outputPath": "dist/angular-issue-test",
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "angular-issue-test:build:production"
            },
            "development": {
              "buildTarget": "angular-issue-test:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "examples/angular-issue-test/**/*.ts",
              "examples/angular-issue-test/**/*.html"
            ]
          }
        }
      }
    },
    "material-integration": {
      "projectType": "application",
      "root": "examples/material-integration",
      "sourceRoot": "examples/material-integration/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/material-integration",
            "browser": "examples/material-integration/src/main.ts",
            "tsConfig": "examples/material-integration/tsconfig.app.json",
            "preserveSymlinks": true,
            "polyfills": [
              "zone.js"
            ],
            "assets": [],
            "styles": [
              "@angular/material/prebuilt-themes/azure-blue.css",
              "examples/material-integration/src/styles.scss"
            ]
          },
          "configurations": {
            "production": {
              "outputPath": "dist/material-integration",
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "material-integration:build:production"
            },
            "development": {
              "buildTarget": "material-integration:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    },
    "ngxsmk-datepicker-element": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/ngxsmk-datepicker-element",
      "sourceRoot": "projects/ngxsmk-datepicker-element/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/ngxsmk-datepicker-element/src/main.ts",
            "tsConfig": "projects/ngxsmk-datepicker-element/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/ngxsmk-datepicker-element/public"
              }
            ],
            "styles": [
              "projects/ngxsmk-datepicker-element/src/styles.css"
            ],
            "extractLicenses": false
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "2mb",
                  "maximumError": "4mb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "ngxsmk-datepicker-element:build:production"
            },
            "development": {
              "buildTarget": "ngxsmk-datepicker-element:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}